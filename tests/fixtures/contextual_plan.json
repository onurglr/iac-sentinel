{
  "format_version": "1.2",
  "resource_changes": [
    {
      "address": "aws_security_group.web",
      "type": "aws_security_group",
      "name": "web",
      "change": {
        "actions": ["create"],
        "before": null,
        "after": {
          "name": "web-sg",
          "ingress": [
            { "from_port": 22, "to_port": 22, "protocol": "tcp", "cidr_blocks": ["0.0.0.0/0"] }
          ]
        }
      }
    },
    {
      "address": "aws_s3_bucket.customer_exports",
      "type": "aws_s3_bucket",
      "name": "customer_exports",
      "change": {
        "actions": ["create"],
        "before": null,
        "after": {
          "bucket": "customer-exports-prod",
          "acl": "public-read"
        }
      }
    },
    {
      "address": "aws_instance.trainer",
      "type": "aws_instance",
      "name": "trainer",
      "change": {
        "actions": ["create"],
        "before": null,
        "after": {
          "instance_type": "p4d.24xlarge",
          "count": 50,
          "tags": { "Name": "ml-trainer" }
        }
      }
    }
  ]
}
